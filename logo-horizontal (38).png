/* ── NovaHSEQ ISO App — Global Styles ── */
:root {
  --nova-blue:   #2563eb;
  --nova-purple: #7c3aed;
  --nova-dark:   #0f172a;
  --nova-card:   #1e293b;
  --nova-border: rgba(255,255,255,.08);
  --nova-text:   #f1f5f9;
  --nova-muted:  #94a3b8;
  --nova-green:  #16a34a;
  --nova-amber:  #d97706;
  --nova-red:    #dc2626;
}
* { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
body { margin: 0; background: var(--nova-dark); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: var(--nova-text); overscroll-behavior: none; }
ion-app { background: var(--nova-dark); }
ion-toolbar { --background: #0f172a; --border-color: var(--nova-border); }
ion-content { --background: #0f172a; }
ion-tab-bar  { --background: #0f172a; --border-color: var(--nova-border); height: 60px; }
ion-tab-button { --color: var(--nova-muted); --color-selected: var(--nova-blue); }
ion-item { --background: var(--nova-card); --color: var(--nova-text); --border-color: var(--nova-border); }
ion-card { --background: var(--nova-card); color: var(--nova-text); border-radius: 16px; box-shadow: none; border: 1px solid var(--nova-border); }
ion-label { color: var(--nova-text) !important; }
ion-note  { color: var(--nova-muted); }
ion-list  { background: transparent !important; }

/* ── KPI Cards ── */
.kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 16px; }
.kpi-card { background: var(--nova-card); border-radius: 16px; padding: 18px 16px; border: 1px solid var(--nova-border); position: relative; overflow: hidden; cursor: pointer; }
.kpi-card .kpi-icon { font-size: 22px; margin-bottom: 10px; }
.kpi-num  { font-size: 32px; font-weight: 900; line-height: 1; margin-bottom: 4px; }
.kpi-lbl  { font-size: 11px; color: var(--nova-muted); font-weight: 600; letter-spacing: .04em; }
.kpi-card.blue   .kpi-num { color: var(--nova-blue); }
.kpi-card.green  .kpi-num { color: var(--nova-green); }
.kpi-card.amber  .kpi-num { color: var(--nova-amber); }
.kpi-card.red    .kpi-num { color: var(--nova-red); }
.kpi-card.purple .kpi-num { color: var(--nova-purple); }

/* ── Task items ── */
.task-item { background: var(--nova-card); border-radius: 12px; padding: 14px 16px; margin: 0 16px 10px; border: 1px solid var(--nova-border); display: flex; gap: 12px; align-items: flex-start; cursor: pointer; transition: border-color .15s; }
.task-item:active { border-color: var(--nova-blue); }
.task-priority { width: 4px; border-radius: 4px; align-self: stretch; flex-shrink: 0; min-height: 40px; }
.task-priority.high   { background: var(--nova-red); }
.task-priority.medium { background: var(--nova-amber); }
.task-priority.low    { background: var(--nova-green); }
.task-priority.critical { background: var(--nova-purple); }
.task-title { font-size: 14px; font-weight: 700; color: var(--nova-text); margin-bottom: 4px; }
.task-sub   { font-size: 12px; color: var(--nova-muted); margin-bottom: 6px; }
.task-badge { display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 20px; font-weight: 700; }
.badge-open        { background: rgba(37,99,235,.2);  color: #93c5fd; }
.badge-in_progress { background: rgba(217,119,6,.2);  color: #fcd34d; }
.badge-completed   { background: rgba(22,163,74,.2);  color: #86efac; }
.badge-critical    { background: rgba(220,38,38,.2);  color: #fca5a5; }

/* ── Forms ── */
.form-section { margin: 0 16px 14px; background: var(--nova-card); border-radius: 16px; padding: 16px; border: 1px solid var(--nova-border); }
.form-section h3 { font-size: 11px; font-weight: 700; color: var(--nova-muted); text-transform: uppercase; letter-spacing: .06em; margin: 0 0 14px; }
.field { margin-bottom: 14px; }
.field:last-child { margin-bottom: 0; }
.field label { display: block; font-size: 11px; font-weight: 700; color: var(--nova-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .04em; }
.field input, .field select, .field textarea {
  width: 100%; background: rgba(255,255,255,.05); border: 1.5px solid var(--nova-border);
  border-radius: 10px; padding: 11px 13px; color: var(--nova-text); font-size: 14px;
  outline: none; transition: border-color .15s; font-family: inherit; -webkit-appearance: none;
}
.field input:focus, .field select:focus, .field textarea:focus { border-color: var(--nova-blue); background: rgba(37,99,235,.06); }
.field select option { background: #1e293b; color: var(--nova-text); }

/* ── Buttons ── */
.btn-primary { width: 100%; background: var(--nova-blue); color: #fff; border: none; border-radius: 12px; padding: 14px; font-size: 15px; font-weight: 800; cursor: pointer; letter-spacing: .02em; transition: opacity .15s; font-family: inherit; }
.btn-primary:active { opacity: .85; }

/* ── Login ── */
.login-wrap { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 32px 24px; }
.login-logo { text-align: center; margin-bottom: 40px; }
.login-shield { width: 72px; height: 72px; background: linear-gradient(135deg, #2563eb, #7c3aed); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 36px; margin: 0 auto 16px; }
.login-logo h1 { font-size: 24px; font-weight: 900; color: var(--nova-text); margin: 0 0 4px; }
.login-logo p  { font-size: 13px; color: var(--nova-muted); margin: 0; }
.login-card { background: var(--nova-card); border-radius: 20px; padding: 24px; border: 1px solid var(--nova-border); }
.login-error { background: rgba(220,38,38,.12); border: 1px solid rgba(220,38,38,.25); border-radius: 10px; padding: 10px 14px; font-size: 13px; color: #fca5a5; margin-bottom: 14px; display: none; }
.login-error.show { display: block; }

/* ── Profile ── */
.profile-hero { text-align: center; padding: 32px 20px 24px; }
.avatar-circle { width: 88px; height: 88px; border-radius: 50%; border: 3px solid var(--nova-blue); background: linear-gradient(135deg, var(--nova-blue), var(--nova-purple)); display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 900; color: #fff; margin: 0 auto 14px; overflow: hidden; }
.avatar-circle img { width: 100%; height: 100%; object-fit: cover; }
.profile-name  { font-size: 20px; font-weight: 800; color: var(--nova-text); margin-bottom: 4px; }
.profile-email { font-size: 13px; color: var(--nova-muted); margin-bottom: 10px; }
.profile-badge { display: inline-block; background: rgba(37,99,235,.2); color: #93c5fd; padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; }
.info-row { display: flex; justify-content: center; gap: 24px; margin-top: 20px; }
.info-block { text-align: center; }
.info-val { font-size: 16px; font-weight: 800; color: var(--nova-text); }
.info-key { font-size: 10px; color: var(--nova-muted); text-transform: uppercase; letter-spacing: .05em; }
.menu-item { display: flex; align-items: center; gap: 14px; padding: 16px; background: var(--nova-card); border: none; border-bottom: 1px solid var(--nova-border); width: 100%; cursor: pointer; color: var(--nova-text); font-size: 14px; font-family: inherit; }
.menu-item:last-child { border-bottom: none; }
.menu-item .icon { font-size: 20px; width: 32px; text-align: center; flex-shrink: 0; }
.menu-item .chevron { margin-left: auto; color: var(--nova-muted); font-size: 16px; }

/* ── IPERC ── */
.risk-item { background: var(--nova-card); border-radius: 12px; padding: 14px 16px; margin: 0 16px 10px; border: 1px solid var(--nova-border); }
.risk-head { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
.risk-name { font-size: 14px; font-weight: 700; color: var(--nova-text); flex: 1; line-height: 1.4; }
.risk-level { font-size: 10px; padding: 2px 8px; border-radius: 20px; font-weight: 700; flex-shrink: 0; }
.risk-level.low      { background: rgba(22,163,74,.2); color: #86efac; }
.risk-level.medium   { background: rgba(217,119,6,.2); color: #fcd34d; }
.risk-level.high     { background: rgba(220,38,38,.2); color: #fca5a5; }
.risk-level.critical { background: rgba(124,58,237,.2); color: #c4b5fd; }
.risk-desc { font-size: 12px; color: var(--nova-muted); line-height: 1.5; }

/* ── Severity selector ── */
.sev-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.sev-btn { padding: 10px 6px; border-radius: 10px; border: 1.5px solid var(--nova-border); background: rgba(255,255,255,.03); color: var(--nova-muted); font-size: 12px; font-weight: 700; cursor: pointer; text-align: center; font-family: inherit; transition: all .15s; }
.sev-btn.sel-low      { border-color: var(--nova-green); background: rgba(22,163,74,.15); color: #86efac; }
.sev-btn.sel-medium   { border-color: var(--nova-amber); background: rgba(217,119,6,.15); color: #fcd34d; }
.sev-btn.sel-high     { border-color: var(--nova-red); background: rgba(220,38,38,.15); color: #fca5a5; }
.sev-btn.sel-critical { border-color: var(--nova-purple); background: rgba(124,58,237,.15); color: #c4b5fd; }

/* ── Section headers ── */
.section-title { font-size: 11px; font-weight: 700; color: var(--nova-muted); text-transform: uppercase; letter-spacing: .08em; padding: 20px 16px 8px; }
.hero-banner { margin: 16px; background: linear-gradient(135deg, rgba(37,99,235,.25), rgba(124,58,237,.15)); border: 1px solid rgba(37,99,235,.3); border-radius: 16px; padding: 20px; }
.hero-title { font-size: 16px; font-weight: 800; color: var(--nova-text); margin-bottom: 4px; }
.hero-sub   { font-size: 13px; color: var(--nova-muted); }

/* ── States ── */
.loading-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 20px; }
.spinner { width: 36px; height: 36px; border: 3px solid rgba(255,255,255,.1); border-top-color: var(--nova-blue); border-radius: 50%; animation: spin .7s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty-wrap { text-align: center; padding: 60px 20px; }
.empty-icon { font-size: 48px; margin-bottom: 12px; opacity: .35; }
.empty-text { color: var(--nova-muted); font-size: 14px; }

/* ── Toast ── */
.app-toast { position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%) translateY(10px); background: #1e293b; color: var(--nova-text); padding: 12px 20px; border-radius: 12px; font-size: 13px; font-weight: 600; border: 1px solid var(--nova-border); box-shadow: 0 8px 30px rgba(0,0,0,.5); z-index: 9999; opacity: 0; transition: opacity .25s, transform .25s; max-width: 90vw; text-align: center; pointer-events: none; }
.app-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
.app-toast.success { border-color: rgba(22,163,74,.4); color: #86efac; }
.app-toast.error   { border-color: rgba(220,38,38,.4); color: #fca5a5; }

/* ── Company selector ── */
#company-list::-webkit-scrollbar { width: 4px; }
#company-list::-webkit-scrollbar-track { background: transparent; }
#company-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 4px; }
