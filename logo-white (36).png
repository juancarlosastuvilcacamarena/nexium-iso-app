// ── Admin Incidents view ──────────────────────────────────────────────────────
Router.register('admin_incidents', () => {
  const wrap = document.createElement('div');
  wrap.innerHTML = `
    <div style="position:sticky;top:0;z-index:10;background:#0f172a;padding:16px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;gap:12px">
      <button onclick="Router.go('admin_dashboard')" style="background:rgba(255,255,255,.08);border:none;border-radius:50%;width:34px;height:34px;color:var(--nova-text);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center">‹</button>
      <div><h2 style="margin:0;font-size:17px;font-weight:900">Incidentes</h2></div>
    </div>
    <div id="inc-list-content"><div class="loading-wrap"><div class="spinner"></div></div></div>
  `;
  Api._req('GET', '/incidents.php').then(res => {
    const items = res?.data || [];
    const el = wrap.querySelector('#inc-list-content');
    if (!items.length) {
      el.innerHTML = `<div class="empty-wrap"><div class="empty-icon">🚨</div><p class="empty-text">Sin incidentes registrados.</p></div>`;
      return;
    }
    el.innerHTML = items.map(i => `
      <div class="task-item">
        <div class="task-priority ${i.severity === 'critical' ? 'critical' : i.severity === 'high' ? 'high' : 'medium'}"></div>
        <div style="flex:1">
          <div class="task-title">${i.incident_code || '—'} · ${i.title}</div>
          <div class="task-sub">${i.area || '—'} · ${fmtDate(i.created_at)}</div>
          <span class="task-badge badge-${i.status === 'closed' ? 'completed' : 'open'}">${i.status || 'reportado'}</span>
        </div>
      </div>`).join('');
  });
  return wrap;
});

// ── Admin Tasks view ──────────────────────────────────────────────────────────
Router.register('admin_tasks', () => {
  const wrap = document.createElement('div');
  wrap.innerHTML = `
    <div style="position:sticky;top:0;z-index:10;background:#0f172a;padding:16px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;gap:12px">
      <button onclick="Router.go('admin_dashboard')" style="background:rgba(255,255,255,.08);border:none;border-radius:50%;width:34px;height:34px;color:var(--nova-text);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center">‹</button>
      <div><h2 style="margin:0;font-size:17px;font-weight:900">Tareas del equipo</h2></div>
    </div>
    <div id="atasks-content"><div class="loading-wrap"><div class="spinner"></div></div></div>
  `;
  Api.getTasks().then(res => {
    const tasks = res?.data || [];
    const el = wrap.querySelector('#atasks-content');
    if (!tasks.length) {
      el.innerHTML = `<div class="empty-wrap"><div class="empty-icon">✅</div><p class="empty-text">Sin tareas pendientes.</p></div>`;
      return;
    }
    el.innerHTML = `<div style="padding-top:8px">` + tasks.map(t => `
      <div class="task-item">
        <div class="task-priority ${t.priority}"></div>
        <div style="flex:1">
          <div class="task-title">${t.title}</div>
          <div class="task-sub">${t.area || '—'} · ${fmtDate(t.due_date)}</div>
          <span class="task-badge badge-${t.status}">${{open:'Pendiente',in_progress:'En progreso',completed:'Completada'}[t.status]||t.status}</span>
        </div>
      </div>`).join('') + `</div>`;
  });
  return wrap;
});

